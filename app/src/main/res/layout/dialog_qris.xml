<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@color/bg_light"
    android:padding="20dp">

    <!-- QRIS Logo Banner Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/white"
        android:padding="12dp"
        android:layout_marginBottom="16dp"
        android:elevation="2dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="QRIS"
            android:textColor="#D93025"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginEnd="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Indonesian Standard"
            android:textColor="#3C4043"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Kas Recipient tags -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="PENERIMA: KAS RT 02 GRAHA CIKARANG"
        android:textAlignment="center"
        android:textColor="@color/text_dark"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tx_qris_house"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Detail Tagihan Rumah:"
        android:textAlignment="center"
        android:textColor="@color/text_muted"
        android:textSize="12sp"
        android:layout_marginTop="3dp" />

    <TextView
        android:id="@+id/tx_qris_billing_id"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Billing-ID RT: RT02GC-X"
        android:textAlignment="center"
        android:textColor="@color/text_muted"
        android:textSize="11sp"
        android:fontFamily="monospace" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="NOMINAL: Rp 50.000,-"
        android:textAlignment="center"
        android:textColor="@color/primary"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginTop="8dp" />

    <!-- SCANNER QR GRID CANVAS MOCK -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="190dp"
        android:layout_height="190dp"
        android:layout_gravity="center"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="10dp"
        app:cardElevation="2dp"
        app:strokeColor="@color/divider_line"
        app:strokeWidth="1dp">

        <!-- Outer camera frame QR layout representation -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/white"
            android:padding="16dp">

            <!-- Core scanning dots simulated in vector layers -->
            <!-- Top-Left QR Code Anchor Block -->
            <View
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="#2E3B4E"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true" />
            <View
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:background="@color/white"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true"
                android:layout_marginStart="8dp"
                android:layout_marginTop="8dp" />

            <!-- Top-Right QR Code Anchor Block -->
            <View
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="#2E3B4E"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true" />
            <View
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:background="@color/white"
                android:layout_alignParentEnd="true"
                android:layout_alignParentTop="true"
                android:layout_marginEnd="8dp"
                android:layout_marginTop="8dp" />

            <!-- Bottom-Left QR Code Anchor Block -->
            <View
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="#2E3B4E"
                android:layout_alignParentStart="true"
                android:layout_alignParentBottom="true" />
            <View
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:background="@color/white"
                android:layout_alignParentStart="true"
                android:layout_alignParentBottom="true"
                android:layout_marginStart="8dp"
                android:layout_marginBottom="8dp" />

            <!-- Random barcode noise boxes to construct real scanner looking -->
            <View
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:background="#2E3B4E"
                android:layout_centerInParent="true" />

            <View
                android:layout_width="20dp"
                android:layout_height="10dp"
                android:background="#2E3B4E"
                android:layout_alignParentEnd="true"
                android:layout_alignParentBottom="true"
                android:layout_marginEnd="20dp"
                android:layout_marginBottom="6dp" />

            <View
                android:layout_width="8dp"
                android:layout_height="45dp"
                android:background="#2E3B4E"
                android:layout_centerVertical="true"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="8dp" />

            <View
                android:layout_width="45dp"
                android:layout_height="8dp"
                android:background="#2E3B4E"
                android:layout_centerHorizontal="true"
                android:layout_alignParentBottom="true"
                android:layout_marginBottom="25dp" />

            <View
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="#10B981"
                android:layout_centerInParent="true" />
        </RelativeLayout>
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pindai QR di atas menggunakan m-Banking atau e-Wallet (Gopay/OVO/Dana) Anda"
        android:textAlignment="center"
        android:textColor="@color/text_muted"
        android:textSize="11sp" />

    <Button
        android:id="@+id/btn_complete_transaction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Konfirmasi Pembayaran Sukses"
        android:backgroundTint="@color/primary" />

</LinearLayout>
